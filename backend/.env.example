DATABASE_URL=postgresql://user:password@host:5432/assetminder
JOBBER_CLIENT_ID=your_jobber_client_id
JOBBER_CLIENT_SECRET=your_jobber_client_secret
JOBBER_WEBHOOK_SECRET=your_jobber_client_secret
JOBBER_REDIRECT_URI=http://localhost:3001/auth/jobber/callback
PORT=3001
# Frontend base URL. Local dev: http://localhost:3000 · Production: https://www.minderapps.io
FRONTEND_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
ADMIN_SECRET_KEY=your_secret_admin_key

# Email/password auth
# SMTP (Namecheap Private Email) — sends password-reset emails. If SMTP_HOST/
# SMTP_USER/SMTP_PASS are unset (e.g. local dev), reset links are logged to the
# server console instead of emailed.
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587                            # 587 = STARTTLS
SMTP_USER=support@minderapps.io
SMTP_PASS=
MAIL_FROM_EMAIL=support@minderapps.io
MAIL_FROM_NAME=AssetMinder
# Base URL for password-reset links (the frontend). Prod: https://www.minderapps.io
APP_BASE_URL=http://localhost:3000
# Enforcement flag for the param->cookie migration. Leave UNSET during rollout;
# set to "true" (Phase 6) once the frontend is on cookies to reject the legacy
# jobberAccountId param and require a valid session on /api/* routes.
AUTH_ENFORCE=
