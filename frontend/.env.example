# Base URL of the AssetMinder backend API.
# Local dev: leave empty — Vite proxies /api to http://localhost:3001.
# Production: https://api.minderapps.io  (backend custom domain — same registrable
#  site as the frontend at https://www.minderapps.io, so the session cookie is
#  first-party. The onrender.com host still works but must NOT be used here, or
#  the cookie becomes third-party and Safari blocks it.)
VITE_API_URL=
