# Base URL of the AssetMinder backend API.
# Local dev: leave empty — Vite proxies /api to http://localhost:3001.
# Production: the deployed backend URL, e.g. https://assetminder-backend.onrender.com
# (The backend did not move in the minderapps.io migration; the frontend is
#  served at https://www.minderapps.io and calls this API.)
VITE_API_URL=
